# =============================================================================
# The Mustang, environment manifest
# -----------------------------------------------------------------------------
# Copy to `.env.local` (Next.js loads it automatically, never committed) and
# fill in the real values. Everything here is SERVER-ONLY; none of these are
# NEXT_PUBLIC_*, so they are never exposed to the browser bundle.
# =============================================================================

# ---- SMTP (reservation + catering emails, src/lib/mailer.ts) ----------------
# The outgoing mail server that delivers form submissions to the restaurant.

# Mail host, e.g. smtp.gmail.com, smtp.office365.com, or your provider's host.
SMTP_HOST=smtp.example.com

# 587 for STARTTLS (most common), 465 for implicit TLS.
SMTP_PORT=587

# "true" for implicit TLS (port 465), "false" for STARTTLS (port 587).
# If omitted, the mailer infers true when SMTP_PORT is 465, else false.
SMTP_SECURE=false

# SMTP username, usually the full mailbox address.
SMTP_USER=bookings@example.com

# SMTP password or app-specific password.
# NOTE: the owner will fill this in. Leave blank in the committed example.
SMTP_PASS=

# The From address on outgoing mail. Falls back to SMTP_USER if unset.
# Some providers require this to match the authenticated mailbox.
SMTP_FROM=bookings@example.com

# Where reservation and catering emails are delivered. If unset, the API route
# falls back to SITE.email (eatthemustangcanberra@gmail.com).
RESERVATION_TO=eatthemustangcanberra@gmail.com

# ---- Anthropic (AI concierge route) -----------------------------------------
# Used by the AI concierge API route. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
